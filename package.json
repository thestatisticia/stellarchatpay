{
  "name": "stellarchat-pay",
  "version": "3.0.0",
  "description": "Chat-based Stellar testnet dApp with payments, escrow, and Soroban contracts",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "contract:build": "cd contracts/payment-log && stellar contract build && cd ../escrow && stellar contract build",
    "contract:test": "cd contracts/payment-log && cargo test && cd ../escrow && cargo test",
    "contract:deploy": "node scripts/deploy-contract.mjs",
    "contract:deploy:escrow": "node scripts/deploy-escrow.mjs"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@stellar/stellar-sdk": "^15.1.0",
    "buffer": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.4.2",
    "vitest": "^3.2.7"
  }
}
