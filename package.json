{
  "name": "stellarchat-pay",
  "version": "2.0.0",
  "description": "Send XLM payments through a chat interface on Stellar testnet",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
